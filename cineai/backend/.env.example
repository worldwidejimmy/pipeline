# ── LLM ──────────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# ── Embeddings ────────────────────────────────────────────────────────────────
# Used for RAG vector search (text-embedding-3-small)
OPENAI_API_KEY=sk-your_openai_key_here

# ── Movie Data ────────────────────────────────────────────────────────────────
# Free TMDB API key: https://www.themoviedb.org/settings/api
# Use the "API Read Access Token" (Bearer token, not the v3 API key)
TMDB_BEARER_TOKEN=eyJhbGc...your_tmdb_bearer_token

# ── Web Search ────────────────────────────────────────────────────────────────
# Optional — enables live web results. Get free key at https://tavily.com
TAVILY_API_KEY=tvly-your_tavily_key_here

# ── Vector Database ───────────────────────────────────────────────────────────
# Reuse the pipeline project's Milvus instance
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=cineai_docs

# ── Models ───────────────────────────────────────────────────────────────────
# Groq models: llama-3.1-70b-versatile, llama3-70b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-70b-versatile

# ── Observability (optional) ─────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__your_langsmith_key
LANGCHAIN_PROJECT=cineai
