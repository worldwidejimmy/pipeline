# ═══════════════════════════════════════════════════════════════════════════
#  SmartMovieSearch — Environment Configuration
#  Copy to .env and fill in your values.
#  Keys marked [REQUIRED] will cause startup errors if missing.
#  Keys marked [OPTIONAL] have working fallbacks.
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM — Anthropic (Claude) ─────────────────────────────────────────────
# Get key: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here                       # [REQUIRED]
# Server-wide model tier: haiku | sonnet | opus
#   haiku  = claude-haiku-4-5  ($1/$5 per 1M)   — default, fast & cheap
#   sonnet = claude-sonnet-4-6 ($3/$15 per 1M)
#   opus   = claude-opus-4-8   ($5/$25 per 1M)
DEFAULT_MODEL_TIER=haiku                                     # [OPTIONAL] change + recreate backend to switch

# ── Movie Data — TMDB ─────────────────────────────────────────────────────
# Get key: https://www.themoviedb.org/settings/api
# Use the "API Read Access Token" (long JWT) NOT the short API key
TMDB_BEARER_TOKEN=eyJhbGc...your_long_jwt_token_here         # [REQUIRED]

# ── Embeddings — OpenAI ───────────────────────────────────────────────────
# Used only for text-embedding-3-small — very low cost (~$0.02/1M tokens)
# Restricted key is fine: enable only "Embeddings → Request" permission
# Alternative: set EMBEDDING_PROVIDER=ollama and run: ollama pull nomic-embed-text
OPENAI_API_KEY=sk-your_openai_key_here                       # [REQUIRED unless EMBEDDING_PROVIDER=ollama]

# ── Web Search — Tavily ───────────────────────────────────────────────────
# Get key: https://tavily.com (free: 1000 searches/month)
# Without this, the search agent returns "unavailable" — other agents still work
TAVILY_API_KEY=tvly-your_tavily_key_here                     # [OPTIONAL]

# ── Vector Database — Milvus ──────────────────────────────────────────────
# When running via docker compose: use service name (http://milvus:19530)
# When running locally (dev): use localhost (http://localhost:19530)
MILVUS_URI=http://localhost:19530                            # [REQUIRED]
MILVUS_COLLECTION=smartmoviesearch_docs                      # [OPTIONAL] collection name

# ── Embedding Provider ────────────────────────────────────────────────────
# openai  → uses text-embedding-3-small via OPENAI_API_KEY (default)
# ollama  → uses nomic-embed-text via local Ollama (no API key needed)
#           requires: ollama pull nomic-embed-text && ollama serve
EMBEDDING_PROVIDER=openai                                    # [OPTIONAL]

# ── Retrieval Settings ────────────────────────────────────────────────────
TOP_K=6                                                      # [OPTIONAL] chunks retrieved per RAG query

# ── Hybrid Search (Milvus 2.5 BM25 + dense) ──────────────────────────────
# HYBRID_RRF_K controls the RRF rank fusion parameter.
# Higher k (e.g. 100) boosts recall; lower k (e.g. 30) sharpens precision.
# Default 60 is a good general-purpose starting point.
HYBRID_RRF_K=60                                              # [OPTIONAL]

# ── Open Access + Per-IP Free Quota ───────────────────────────────────────
# The site is public. Anonymous visitors get FREE_REQUESTS_PER_WINDOW searches
# per rolling FREE_WINDOW_SECONDS per IP. Signing in with PREVIEW_PASSWORD lifts
# the limit (unlimited). Leaving PREVIEW_PASSWORD blank means there is no way to
# unlock unlimited access — everyone stays rate-limited.
PREVIEW_PASSWORD=your_preview_password_here                  # password for unlimited access
FREE_REQUESTS_PER_WINDOW=10                                  # [OPTIONAL] free searches per IP per window
FREE_WINDOW_SECONDS=3600                                     # [OPTIONAL] window length (default: 1 hour)
# Token meter shows cumulative tokens used today by everyone (your paid Anthropic
# spend). Optional soft budget for the meter denominator; 0 = show raw count only.
DAILY_TOKEN_BUDGET=0                                         # [OPTIONAL] meter denominator
# Hard kill-switch: when today's total tokens hit this, anonymous LLM calls pause
# until tomorrow (signed-in/admin still works). 0 = disabled. Protects paid spend.
DAILY_TOKEN_HARD_CAP=0                                       # [OPTIONAL] e.g. 2000000
# Site-wide ceiling on anonymous searches per day (research/showcase project).
# Each search counts as 1; signed-in/admin bypasses. 0 = disabled.
GLOBAL_DAILY_CALL_CAP=30                                     # [OPTIONAL] ~30 searches/day site-wide

# ── LangSmith Observability (optional but recommended) ────────────────────
# Get key: https://smith.langchain.com → Settings → API Keys
# When enabled, all LangGraph traces appear in the LangSmith UI
LANGCHAIN_TRACING_V2=false                                   # [OPTIONAL] set to true to enable
LANGCHAIN_API_KEY=ls__your_langsmith_key                     # [OPTIONAL]
LANGCHAIN_PROJECT=smartmoviesearch                           # [OPTIONAL]
