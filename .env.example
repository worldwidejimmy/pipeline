# ── LLM Backend ──────────────────────────────────────────────────────────────
# Choose one: openai or ollama
LLM_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama (local, no key needed – set LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Milvus ────────────────────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=research_docs

# Embedding model (used when inserting + querying)
# "openai"  → text-embedding-3-small (requires OPENAI_API_KEY)
# "ollama"  → nomic-embed-text (requires Ollama running locally)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ── Web Search ────────────────────────────────────────────────────────────────
# Tavily (https://app.tavily.com – free tier available)
TAVILY_API_KEY=tvly-...

# ── LangSmith (optional — traces every agent step in the LangSmith UI) ─────────────────
# Sign up at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=research-pipeline

# ── Pipeline Behaviour ────────────────────────────────────────────────────────
# Max documents to retrieve from Milvus per query
RAG_TOP_K=5

# Max search results from Tavily
SEARCH_MAX_RESULTS=5

# Temperature for the supervisor / synthesis step
SUPERVISOR_TEMPERATURE=0.2
