#!/usr/bin/env bash
# Backstop: scan every commit about to leave this machine — this repo is PUBLIC.
# Catches commits created with --no-verify or on other tooling. Git feeds us
# lines of: <local ref> <local sha> <remote ref> <remote sha>
set -u
zero=0000000000000000000000000000000000000000
empty_tree=4b825dc642cb6eb9a060e54bf8d69288fbee4904
here="$(cd "$(dirname "$0")" && pwd)"
fail=0
while read -r _lref lsha _rref rsha; do
  [ "$lsha" = "$zero" ] && continue                # ref deletion — nothing outgoing
  if [ "$rsha" = "$zero" ]; then base="$empty_tree"; else base="$rsha"; fi
  "$here/guard-scan.sh" pre-push -- "$base" "$lsha" || fail=1
done
exit "$fail"
