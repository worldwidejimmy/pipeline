#!/usr/bin/env bash
# Backstop: scan every commit about to leave this machine — this repo is PUBLIC.
# Catches commits created with --no-verify or on other tooling. Git feeds us
# lines of: <local ref> <local sha> <remote ref> <remote sha>
set -u
zero=0000000000000000000000000000000000000000
empty_tree=4b825dc642cb6eb9a060e54bf8d69288fbee4904
here="$(cd "$(dirname "$0")" && pwd)"
fail=0
while read -r _lref lsha _rref rsha; do
  [ "$lsha" = "$zero" ] && continue                # ref deletion — nothing outgoing
  if [ "$rsha" = "$zero" ]; then base="$empty_tree"; range="$lsha"; else base="$rsha"; range="$rsha..$lsha"; fi
  "$here/guard-scan.sh" pre-push -- "$base" "$lsha" || fail=1

  # Author/committer identities on outgoing commits must not leak box identities,
  # and must match the approved public identity when one is configured.
  idents=$(git log --format='%an <%ae>%n%cn <%ce>' "$range" 2>/dev/null | sort -u)
  bad=$(printf '%s\n' "$idents" | grep -E 'ubuntu@|root@|@vps|\.vps\.ovh\.|localhost' || true)
  if [ -n "$bad" ]; then
    printf '🛑 public-repo guard (pre-push): outgoing commit has a box-default identity:\n%s\n' "$bad" >&2
    fail=1
  fi
  approved_file="$HOME/.config/sms-repo-guard/identity.txt"
  if [ -f "$approved_file" ]; then
    approved="$(head -1 "$approved_file")"
    # GitHub's own merge-commit committer is fine; everything else must match.
    unapproved=$(printf '%s\n' "$idents" | grep -vFx -- "$approved" | grep -vFx 'GitHub <noreply@github.com>' || true)
    if [ -n "$unapproved" ]; then
      printf '🛑 public-repo guard (pre-push): outgoing commit identity is not the approved one:\n%s\n' "$unapproved" >&2
      fail=1
    fi
  fi
done
exit "$fail"
